  "query": "SELECT id, status::text AS \"status!\", attempts, error,\n                  progress, current_step,\n                  stats_json AS \"stats_json!\",\n                  created_at, updated_at\n           FROM jobs\n           WHERE tenant_id = $1\n             AND job_type = 'scan'\n             AND payload->>'target_id' = $2\n           ORDER BY created_at DESC\n           LIMIT 1",
