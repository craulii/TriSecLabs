{
  "db_name": "PostgreSQL",
  "query": "SELECT u.id            AS user_id,\n                  u.tenant_id,\n                  u.email,\n                  u.role::text       AS \"role!\",\n                  u.password_hash\n           FROM users u\n           JOIN tenants t ON t.id = u.tenant_id\n           WHERE t.slug  = $1\n             AND u.email = $2\n             AND u.active = true",
