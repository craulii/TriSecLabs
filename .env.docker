# .env.docker — Template de variables para entornos Docker
#
# Copiar a .env.docker.local y editar con valores reales.
# NUNCA commitear .env.docker.local.
#
#   cp .env.docker .env.docker.local

# =============================================================================
# PostgreSQL
# =============================================================================
# Usada por el servicio postgres (POSTGRES_PASSWORD) y en DATABASE_URL.
# En docker-compose.yml el servidor sobreescribe DATABASE_URL con esta variable.
POSTGRES_PASSWORD=CHANGE_ME

# Service name "postgres" — NO usar localhost dentro de containers Docker.
DATABASE_URL=postgres://app_user:CHANGE_ME@postgres:5432/triseclabs

# =============================================================================
# JWT
# =============================================================================
# Generar: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_MIN_32_CHARS

# =============================================================================
# LLM
# =============================================================================
# Service name "llama" — NO usar localhost.
LLM_BASE_URL=http://llama:8080
LLM_MODEL=mistral-7b-instruct

# =============================================================================
# Servidor
# =============================================================================
# CRÍTICO: 0.0.0.0 para que Axum escuche en todas las interfaces del container.
# Con 127.0.0.1, el servidor solo es accesible desde dentro del mismo container.
# (docker-compose.yml lo sobreescribe, pero tenerlo aquí evita confusión)
HOST=0.0.0.0
PORT=3000

# =============================================================================
# Logging
# =============================================================================
RUST_LOG=info,triseclabs=debug

# =============================================================================
# sqlx offline mode
# =============================================================================
# false en runtime (el binario ya fue compilado con SQLX_OFFLINE=true en el
# Dockerfile). Esta variable no afecta el runtime, solo el compile-time.
SQLX_OFFLINE=false
