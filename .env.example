# Base de datos
DATABASE_URL=postgres://app_user:dev_password@localhost:5432/triseclabs

# JWT — generar con: openssl rand -base64 64
JWT_SECRET=change_me_in_production

# LLM local (llama.cpp server)
LLM_BASE_URL=http://localhost:8080
LLM_MODEL=mistral-7b-instruct

# Servidor
HOST=127.0.0.1
PORT=3000

# Logs
RUST_LOG=info,triseclabs=debug

# sqlx (para CI sin DB viva)
SQLX_OFFLINE=false
